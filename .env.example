# Inkwell Environment Configuration

# MariaDB Connection Details
DB_HOST=db
DB_NAME=dmarc
DB_USER=dmarcuser
DB_PASSWORD=dmarcpass
DB_ROOT_PASSWORD=root_password

# How often to check for new emails (in seconds)
FETCH_INTERVAL=300

# Web Server
PORT=8080

# Dashboard Authentication (leave blank to disable)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Encryption key for IMAP passwords stored in the database
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
